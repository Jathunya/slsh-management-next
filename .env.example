DATABASE_URL="postgresql://slsh:slsh_dev_password@localhost:5433/slsh_tracker?schema=public"
NEXTAUTH_SECRET="replace-with-a-random-32-byte-base64-string"
# NEXTAUTH_URL is optional in dev — NextAuth infers the origin from the request.
# Only set it if you deploy behind a proxy that needs a fixed canonical URL.

# Required when running `npm run start` / the Docker image (production mode).
# Without it, Auth.js rejects requests with "UntrustedHost" since it can no
# longer assume the Host header is safe to trust automatically like it does in dev.
AUTH_TRUST_HOST=true
